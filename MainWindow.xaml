<Window x:Class="ReceitasAtelie.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ateliê de Receitas" 
        Height="650" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#FFF5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Barra Superior (Busca e Ações) -->
            <RowDefinition Height="Auto"/>
            <!-- Área de Conteúdo (Menu Lateral + Cards) -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- BARRA SUPERIOR -->
        <Border Grid.Row="0" Background="#FF3B143A" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Botão Hambúrguer para Recolher/Expandir Menu -->
                <Button Grid.Column="0" Content="☰" Click="BtnHamburguer_Click" 
                        Background="Transparent" BorderBrush="Transparent" Foreground="White" 
                        FontSize="20" Padding="5,0,15,0" Cursor="Hand" VerticalAlignment="Center"/>

                <!-- Título do App ou Campo de Busca -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Minhas Receitas" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <TextBox x:Name="TxtPesquisa" Width="250" Padding="8,4" BorderThickness="0" Margin="10,0,0,0" 
                             TextAlignment="Left" VerticalAlignment="Center" Tag="Buscar receita..."/>

                    <!-- BOTÃO ATUALIZAR DISCRETO -->
                    <Button x:Name="BtnAtualizar" 
                            Click="BtnAtualizar_Click"
                            Width="30" Height="30" 
                            Margin="8,0,0,0"
                            ToolTip="Atualizar Lista"
                            Cursor="Hand"
                            Background="Transparent" 
                            BorderThickness="0"
                            VerticalAlignment="Center">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" 
                                                    Background="{TemplateBinding Background}" 
                                                    CornerRadius="15" 
                                                    SnapsToDevicePixels="true">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <!-- Hover suave que combina com o fundo escuro -->
                                                <Trigger Property="IsMouseOver" Value="true">
                                                    <Setter Property="Background" TargetName="border" Value="#33FFFFFF"/>
                                                </Trigger>
                                                <!-- Clique -->
                                                <Trigger Property="IsPressed" Value="true">
                                                    <Setter Property="Background" TargetName="border" Value="#FFD47FA6"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>

                        <TextBlock Text="⟳" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="White" 
                                   VerticalAlignment="Center" 
                                   HorizontalAlignment="Center"
                                   Margin="0,-3,0,0"/>
                    </Button>
                </StackPanel>

                <!-- Botão para Cadastrar Nova Receita -->
                <Button Grid.Column="2" Content="+ Nova Receita" Click="BtnNovaReceita_Click" 
                        Padding="15,8" Background="#FFD47FA6" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- ÁREA CENTRAL (MENU + LISTA) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Coluna do Menu Lateral -->
                <ColumnDefinition x:Name="MenuColumn" Width="250"/>
                <!-- Divisor de Colunas (Splitter opcional) -->
                <ColumnDefinition Width="Auto"/>
                <!-- Coluna Principal (Cards de Receitas) -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- PAINEL LATERAL (CATEGORIAS) -->
            <Border Grid.Column="0" Background="#FFE6D5E3" BorderBrush="#FFD47FA6" BorderThickness="0,0,1,0">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- AJUSTADO: ItemsSource para CategoriasRaiz para respeitar a estrutura de árvore -->
                    <TreeView Grid.Row="0" x:Name="TvMenus" Background="Transparent" BorderThickness="0" 
                              ItemsSource="{Binding CategoriasRaiz}"
                              SelectedItemChanged="TvMenus_SelectedItemChanged">
                        <!-- Template para exibir as categorias -->
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Subcategorias}">
                                <TextBlock Text="{Binding Nome}" FontSize="14" Foreground="#FF3B143A" Margin="2,4"/>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>

                    <!-- Ações de Categoria -->
                    <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,10,0,0">
                        <Button x:Name="BtnAdicionarMenu" Content="+ Adicionar Categoria" Margin="0,0,0,5" 
                                Padding="8" Background="#FFD47FA6" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand" Click="BtnAdicionarMenu_Click"/>
                        <Button x:Name="BtnExcluirMenu" Content="- Excluir Categoria" Click="BtnExcluirMenu_Click"
                                Padding="8" Background="#999999" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Separador Visual -->
            <GridSplitter Grid.Column="1" Width="1" Background="#FFD47FA6" HorizontalAlignment="Stretch" Focusable="False"/>

            <!-- LISTA DE CARDS -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" Margin="15">
                <!-- AJUSTADO: ItemsSource alterado para ReceitasExibidas para bater com a ViewModel -->
                <ItemsControl x:Name="ListaReceitasCards" ItemsSource="{Binding ReceitasExibidas}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Margin="5"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Click="CardReceita_Click" Tag="{Binding}" Background="Transparent" BorderBrush="Transparent" Padding="0" Margin="10" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Button.Template>

                                <Border Width="160" Height="220" Background="White" CornerRadius="8" BorderBrush="#FFD47FA6" BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" Color="#CCCCCC" ShadowDepth="2" Direction="315"/>
                                    </Border.Effect>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="45"/>
                                        </Grid.RowDefinitions>

                                        <!-- Capa da Receita -->
                                        <Border Grid.Row="0" CornerRadius="7,7,0,0" ClipToBounds="True">
                                            <!-- Usando caminhos relativos simplificados para o placeholder em Assets -->
                                            <Image Source="{Binding CaminhoImagemCapa, TargetNullValue='pack://application:,,,/Assets/placeholder-receita.png', FallbackValue='pack://application:,,,/Assets/placeholder-receita.png'}" 
                                                   Stretch="UniformToFill" 
                                                   HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center"/>
                                        </Border>

                                        <Separator Grid.Row="1" Height="1" Background="#FFD47FA6" Margin="0"/>

                                        <!-- Título -->
                                        <Border Grid.Row="2" Background="White" CornerRadius="0,0,7,7">
                                            <TextBlock Text="{Binding Titulo}" 
                                                       FontWeight="Bold" 
                                                       FontSize="13" 
                                                       Foreground="Black" 
                                                       TextAlignment="Center" 
                                                       VerticalAlignment="Center" 
                                                       HorizontalAlignment="Stretch"
                                                       TextWrapping="Wrap" 
                                                       Margin="5,2"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>