<Window x:Class="ReceitasAtelie.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReceitasAtelie"
        mc:Ignorable="d"
        Title="Receitas Ateliê do Artes de Cristal" 
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">

    <!-- O Grid Principal serve para sobrepor os elementos acima do fundo -->
    <Grid>

        <!-- 1. IMAGEM DE FUNDO (TELA CHEIA) -->
        <Image Source="/Assets/fundo.png" 
               Stretch="Fill" 
               HorizontalAlignment="Center" 
               VerticalAlignment="Center"/>

        <!-- 2. ESTRUTURA DE LAYOUT (Divide o Menu Lateral da Área de Conteúdo) -->
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Coluna 0: Menu Lateral (Começa com largura automática para o botão hambúrguer) -->
                <ColumnDefinition Width="Auto" x:Name="MenuColumn"/>
                <!-- Coluna 1: Área Principal das Receitas (Ocupa o resto da tela) -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ======================================================= -->
            <!-- PAINEL DO MENU LATERAL (COLUNA 0)                      -->
            <!-- ======================================================= -->
            <Border Grid.Column="0" 
                    Background="#EE3B143A" 
                    BorderBrush="#FFD47FA6" 
                    BorderThickness="0,0,2,0"
                    MinWidth="60">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Topo: Botão Hambúrguer -->
                        <RowDefinition Height="*"/>
                        <!-- Centro: Árvore de Menus -->
                        <RowDefinition Height="Auto"/>
                        <!-- Rodapé: Botões de Ação -->
                    </Grid.RowDefinitions>

                    <!-- Botão Hambúrguer -->
                    <Button Grid.Row="0" 
                            Content="☰" 
                            FontSize="24" 
                            Foreground="White" 
                            Background="Transparent" 
                            BorderThickness="0"
                            Padding="15,10"
                            HorizontalAlignment="Left"
                            Cursor="Hand"
                            x:Name="BtnHamburguer"
                            Click="BtnHamburguer_Click"/>

                    <!-- O componente da Árvore de Menus (Invisível por padrão até expandir) -->
                    <TreeView Grid.Row="1" 
                              x:Name="TvMenus"
                              Background="Transparent" 
                              BorderThickness="0" 
                              Margin="10"
                              Visibility="Collapsed"
                              ItemsSource="{Binding CategoriasRaiz}">

                        <TreeView.ItemTemplate>
                            <!-- O HierarchicalDataTemplate vincula o nó atual e diz onde estão os filhos -->
                            <HierarchicalDataTemplate ItemsSource="{Binding Subcategorias}">
                                <TextBlock Text="{Binding Nome}" 
                                           Foreground="White" 
                                           FontSize="16" 
                                           Margin="0,5"/>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>

                    <!-- Painel de Botões de Ação no Rodapé (Linha 2) -->
                    <StackPanel Grid.Row="2" Margin="10,0,10,10">
                        <Button Content="+ Adicionar Menu" 
                                Margin="0,0,0,5" 
                                Padding="8,5"
                                Background="#FFD47FA6" 
                                Foreground="White" 
                                FontWeight="Bold"
                                BorderThickness="0"
                                Visibility="Collapsed"
                                x:Name="BtnAdicionarMenu"
                                Click="BtnAdicionarCategoria_Click"/>

                        <Button Content="✕ Excluir Selecionado" 
                                Padding="8,5"
                                Background="#A33636" 
                                Foreground="White" 
                                FontWeight="Bold"
                                BorderThickness="0"
                                Visibility="Collapsed"
                                x:Name="BtnExcluirMenu"
                                Click="BtnExcluirMenu_Click"/>
                    </StackPanel>

                </Grid>
            </Border>

            <!-- ======================================================= -->
            <!-- ÁREA DE CONTEÚDO PRINCIPAL (COLUNA 1)                  -->
            <!-- ======================================================= -->
            <Grid Grid.Column="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Linha dos Filtros -->
                    <RowDefinition Height="*"/>
                    <!-- Linha do Grid de Receitas -->
                </Grid.RowDefinitions>

                <!-- Barra de Filtros -->
                <Border Grid.Row="0" 
                        Background="#88FFFFFF" 
                        CornerRadius="8" 
                        Padding="15,10" 
                        Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Campo de Busca por texto -->
                        <TextBox Grid.Column="0" 
                                 Text="Buscar receita..." 
                                 Foreground="Gray"
                                 Background="White" 
                                 Padding="8,5" 
                                 BorderThickness="1" 
                                 BorderBrush="#FFD47FA6"
                                 VerticalContentAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Área onde o DataGrid/Cards de Receitas vai aparecer -->
                <Border Grid.Row="1" 
                        Background="#88FFFFFF" 
                        CornerRadius="12" 
                        Padding="15">

                    <TextBlock Text="Selecione uma categoria no menu para ver as receitas." 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center" 
                               Foreground="#FF3B143A" 
                               FontSize="16" 
                               FontWeight="Medium"/>
                </Border>
            </Grid>

        </Grid>
    </Grid>
</Window>